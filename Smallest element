public class SmallestElement {
    public static void main(String[] args) {

        int[] a = {15, 35, 17, 9, 24};

        int smallest= a[0];

        for(int i = 1; i < a.length; i++) {
            if(a[i] < smallest) {
                smallest = a[i];
            }
        }

        System.out.println("Smallest element = " + smallest);
    }
}
